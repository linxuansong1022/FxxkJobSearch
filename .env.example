# Google Cloud / Vertex AI API Key (REQUIRED)
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_CLOUD_API_KEY=your_api_key_here

# GCP Project ID (Optional if using API Key, Required for ADC)
GCP_PROJECT_ID=your_project_id

# GCP Location (Default: us-central1)
GCP_LOCATION=us-central1

# Tavily Search API Key (REQUIRED)
# Get from: https://tavily.com/
TAVILY_API_KEY=your_tavily_key_here

# Telegram Bot (REQUIRED for notifications)
# Create bot: https://t.me/BotFather
# Get chat ID: https://t.me/userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Log Level (INFO, DEBUG, WARNING, ERROR)
LOG_LEVEL=INFO

# Lightweight Mode (skip Playwright/Chromium, use only Tavily+Jobindex+TheHub)
# Recommended for servers with <= 512MB RAM
LIGHTWEIGHT_MODE=false
